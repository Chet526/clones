# GeoBrief LE — environment configuration template
#
# Copy to `.env` and fill in real values. NEVER commit `.env` or real secrets
# to version control. Deploy secrets with `netlify env:set`, `fly secrets set`,
# or your platform's secret manager.

# ── Core ─────────────────────────────────────────────────────────────────────
# Local case workspace (SQLite DB, preserved originals, billing state).
#GEOBRIEF_HOME=~/.geobrief

# Active plan for local/self-hosted use: standard | pro.
# Overridden by a real Stripe subscription or a valid license key.
#GEOBRIEF_PLAN=standard

# Signed license key issued after purchase (unlocks the plan offline).
#GEOBRIEF_LICENSE_KEY=

# Secret used to sign/verify license keys. Required to VERIFY keys in the app
# and to ISSUE keys from the storefront webhook. Keep it private.
#GEOBRIEF_LICENSE_SECRET=

# ── AI assistant (OpenRouter) ────────────────────────────────────────────────
# Without a key the assistant runs 100% locally — nothing leaves the machine.
#OPENROUTER_API_KEY=
# Recommended model for an intelligent assistant:
#OPENROUTER_MODEL=anthropic/claude-sonnet-4
#OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
#GEOBRIEF_ASSISTANT_ENABLED=      # force on/off; default follows the API key
#GEOBRIEF_ASSISTANT_TEMPERATURE=0.2
#GEOBRIEF_ASSISTANT_MAX_TOKENS=700
#GEOBRIEF_ASSISTANT_TIMEOUT=30

# ── Billing (Stripe) ─────────────────────────────────────────────────────────
# Use test-mode keys (sk_test_...) until launch.
#STRIPE_SECRET_KEY=
#STRIPE_WEBHOOK_SECRET=
#STRIPE_PRICE_STANDARD=           # recurring Price id for the $9.99 plan
#STRIPE_PRICE_PRO=                # recurring Price id for the $14.99 plan
# Optional preset Stripe Payment Links (for the Netlify storefront checkout
# function). If set, these are used instead of creating Checkout Sessions.
#STRIPE_PAYMENT_LINK_STANDARD=
#STRIPE_PAYMENT_LINK_PRO=
#STRIPE_SUCCESS_URL=http://localhost:8000/?checkout=success
#STRIPE_CANCEL_URL=http://localhost:8000/?checkout=cancelled
#GEOBRIEF_BILLING_STORE=          # default: $GEOBRIEF_HOME/billing.json
